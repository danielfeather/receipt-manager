{
    "tasks": {
        "dev": "OTEL_SERVICE_NAME=vite deno run -A npm:vite --host 0.0.0.0 & deno run server:start",
        "build": "deno run -A npm:vite build",
        "server:start": "cargo run --features=debug",
        "serve": "deno run build && deno run --cached-only server:start"
    },
    "vendor": true,
    "nodeModulesDir": "auto",
    "imports": {
        "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.18",
        "feather-icons": "npm:feather-icons@^4.29.2",
        "govuk-frontend": "npm:govuk-frontend@^6.2.0",
        "sass-embedded": "npm:sass-embedded@^1.100.0",
        "vite": "npm:vite@^8.0.10"
    }
}